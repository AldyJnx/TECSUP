generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["lab13"]
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  password       String?
  image          String?
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())

  @@schema("lab13")
}
