<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Página no encontrada</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

<!-- Navbar -->
<nav class="white">
    <div class="nav-wrapper container">
        <a href="/" class="brand-logo grey-text text-darken-3">Mi Sitio</a>
        <ul id="nav-mobile" class="right hide-on-med-and-down">
            <li><a href="/" class="grey-text text-darken-2">Inicio</a></li>
            <li><a href="/about" class="grey-text text-darken-2">Acerca de</a></li>
            <li><a href="/contact" class="grey-text text-darken-2">Contacto</a></li>
            <li><a href="/games" class="grey-text text-darken-2">Videojuegos</a></li>
            <li><a href="/admin" class="grey-text text-darken-2">Admin</a></li>
        </ul>
    </div>
</nav>

<!-- Error Content -->
<div class="container section" style="min-height: 70vh; display: flex; align-items: center; justify-content: center;">
    <div class="row">
        <div class="col s12 center-align">
            <i class="material-icons" style="font-size: 120px; color: #9e9e9e;">error_outline</i>

            <h1 class="grey-text text-darken-3" style="font-size: 4rem; margin: 20px 0;">404</h1>

            <h5 class="grey-text text-darken-2">Página no encontrada</h5>

            <div class="card-panel grey lighten-5" style="margin: 30px auto; max-width: 500px;">
                <p class="grey-text text-darken-1">
                    La ruta <code class="grey lighten-3" style="padding: 2px 6px; border-radius: 3px;"><%= url %></code> no existe
                </p>
            </div>

            <div style="margin-top: 40px;">
                <a href="/" class="btn-large grey darken-2 waves-effect waves-light">
                    <i class="material-icons left">home</i>
                    Volver al inicio
                </a>
            </div>

            <div style="margin-top: 30px;">
                <p class="grey-text">
                    <a href="/about" class="grey-text text-darken-2">Acerca de</a> ·
                    <a href="/contact" class="grey-text text-darken-2">Contacto</a> ·
                    <a href="/admin" class="grey-text text-darken-2">Admin</a>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Footer -->
<footer class="page-footer white">
    <div class="footer-copyright">
        <div class="container center-align grey-text text-darken-2">
            2026 Mi Sitio Express
        </div>
    </div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>