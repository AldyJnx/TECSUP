<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

<!-- Navbar -->
<nav class="white">
    <div class="nav-wrapper container">
        <a href="/" class="brand-logo grey-text text-darken-3">Mi Sitio</a>
        <ul id="nav-mobile" class="right hide-on-med-and-down">
            <li><a href="/" class="grey-text text-darken-2">Inicio</a></li>
            <li><a href="/about" class="grey-text text-darken-2">Acerca de</a></li>
            <li><a href="/contact" class="grey-text text-darken-2">Contacto</a></li>
            <li><a href="/games" class="grey-text text-darken-2">Videojuegos</a></li>
            <li><a href="/admin" class="grey-text text-darken-2">Admin</a></li>
        </ul>
    </div>
</nav>

<!-- Header Section -->
<div class="hero-section grey lighten-4">
    <div class="container center-align">
        <h1 class="grey-text text-darken-3">Panel de Administración</h1>
        <p class="flow-text grey-text text-darken-1">Gestión de mensajes recibidos</p>
    </div>
</div>

<!-- Admin Content -->
<div class="container section">
    <!-- Stats Card -->
    <div class="row">
        <div class="col s12 m6 offset-m3">
            <div class="card grey lighten-5">
                <div class="card-content center-align">
                    <i class="material-icons large grey-text text-darken-2">assessment</i>
                    <h5 class="grey-text text-darken-3"><%= messages.length %></h5>
                    <p class="grey-text">Mensajes totales</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="row">
        <div class="col s12 center-align">
            <a href="/contact" class="btn grey darken-2 waves-effect waves-light">
                <i class="material-icons left">add</i>
                Nuevo mensaje
            </a>
        </div>
    </div>

    <!-- Messages List -->
    <div class="row">
        <div class="col s12">
            <% if (messages.length === 0) { %>
                <div class="card-panel grey lighten-5 center-align">
                    <i class="material-icons large grey-text">inbox</i>
                    <h5 class="grey-text text-darken-1">No hay mensajes</h5>
                    <p class="grey-text">Los mensajes recibidos aparecerán aquí</p>
                    <a href="/contact" class="btn grey darken-2 waves-effect waves-light">
                        Enviar primer mensaje
                    </a>
                </div>
            <% } else { %>
                <h5 class="grey-text text-darken-3">
                    <i class="material-icons left">mail</i>
                    Mensajes recibidos
                </h5>
                <ul class="collection">
                    <% messages.forEach((m, index) => { %>
                        <li class="collection-item avatar">
                            <i class="material-icons circle grey darken-2">person</i>
                            <span class="title grey-text text-darken-3"><%= m.nombre %></span>
                            <p class="grey-text text-darken-1">
                                <i class="material-icons tiny">email</i> <%= m.email %>
                                <br>
                                <span class="grey-text"><%= m.mensaje %></span>
                            </p>
                            <span class="badge grey white-text"><%= index + 1 %></span>
                        </li>
                    <% }) %>
                </ul>
            <% } %>
        </div>
    </div>
</div>

<!-- Footer -->
<footer class="page-footer white">
    <div class="footer-copyright">
        <div class="container center-align grey-text text-darken-2">
            2026 Mi Sitio Express
        </div>
    </div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>