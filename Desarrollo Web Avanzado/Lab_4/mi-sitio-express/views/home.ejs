<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

<!-- Navbar -->
<nav class="white">
    <div class="nav-wrapper container">
        <a href="/" class="brand-logo grey-text text-darken-3">Mi Sitio</a>
        <ul id="nav-mobile" class="right hide-on-med-and-down">
            <li><a href="/" class="grey-text text-darken-2">Inicio</a></li>
            <li><a href="/about" class="grey-text text-darken-2">Acerca de</a></li>
            <li><a href="/contact" class="grey-text text-darken-2">Contacto</a></li>
            <li><a href="/games" class="grey-text text-darken-2">Videojuegos</a></li>
            <li><a href="/admin" class="grey-text text-darken-2">Admin</a></li>
        </ul>
    </div>
</nav>

<!-- Hero Section -->
<div class="hero-section grey lighten-4">
    <div class="container center-align">
        <h1 class="grey-text text-darken-3">Bienvenido</h1>
        <p class="flow-text grey-text text-darken-1">Descubre nuestra plataforma simple y elegante</p>
    </div>
</div>

<!-- Cards Section -->
<div class="container section">
    <div class="row">
        <div class="col s12 m6 l3">
            <div class="card hoverable">
                <div class="card-content center-align">
                    <i class="material-icons large grey-text text-darken-2">info</i>
                    <span class="card-title grey-text text-darken-3">Acerca de</span>
                    <p class="grey-text">Conoce más sobre nosotros y nuestra misión.</p>
                </div>
                <div class="card-action center-align">
                    <a href="/about" class="grey-text text-darken-2">Ver más</a>
                </div>
            </div>
        </div>

        <div class="col s12 m6 l3">
            <div class="card hoverable">
                <div class="card-content center-align">
                    <i class="material-icons large grey-text text-darken-2">contact_mail</i>
                    <span class="card-title grey-text text-darken-3">Contacto</span>
                    <p class="grey-text">Envíanos un mensaje, estamos aquí para ayudarte.</p>
                </div>
                <div class="card-action center-align">
                    <a href="/contact" class="grey-text text-darken-2">Contactar</a>
                </div>
            </div>
        </div>

        <div class="col s12 m6 l3">
            <div class="card hoverable">
                <div class="card-content center-align">
                    <i class="material-icons large grey-text text-darken-2">videogame_asset</i>
                    <span class="card-title grey-text text-darken-3">Videojuegos</span>
                    <p class="grey-text">Gestiona tu colección de videojuegos favoritos.</p>
                </div>
                <div class="card-action center-align">
                    <a href="/games" class="grey-text text-darken-2">Explorar</a>
                </div>
            </div>
        </div>

        <div class="col s12 m6 l3">
            <div class="card hoverable">
                <div class="card-content center-align">
                    <i class="material-icons large grey-text text-darken-2">admin_panel_settings</i>
                    <span class="card-title grey-text text-darken-3">Administración</span>
                    <p class="grey-text">Panel de administración de mensajes.</p>
                </div>
                <div class="card-action center-align">
                    <a href="/admin" class="grey-text text-darken-2">Acceder</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Footer -->
<footer class="page-footer white">
    <div class="footer-copyright">
        <div class="container center-align grey-text text-darken-2">
            2026 Mi Sitio Express
        </div>
    </div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>