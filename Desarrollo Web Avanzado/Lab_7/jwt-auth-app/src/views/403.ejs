<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <div id="nav-slot"></div>
  <div class="error-shell">
    <div class="error-card">
      <div class="error-code">403</div>
      <div class="error-title">Acceso denegado</div>
      <p class="error-sub">No cuentas con los privilegios necesarios para ver esta pagina. Si crees que es un error, contacta a un administrador.</p>
      <div class="error-actions">
        <a href="/dashboard" class="btn btn-secondary">Ir al inicio</a>
        <button class="btn" id="logoutBtn">Cerrar sesion</button>
      </div>
    </div>
  </div>

  <script src="/js/auth.js"></script>
  <script>
    if (Auth.isAuthenticated()) mountNav('');
    document.getElementById('logoutBtn').addEventListener('click', () => Auth.logout());
  </script>
</body>
</html>
