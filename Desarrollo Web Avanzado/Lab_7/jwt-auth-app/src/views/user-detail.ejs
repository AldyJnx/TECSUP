<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <div id="nav-slot"></div>

  <main class="page" style="max-width: 880px;">
    <header class="page-header">
      <div>
        <div class="muted" style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px;">Administracion</div>
        <h1 class="page-title">Detalle de usuario</h1>
        <p class="page-subtitle">Consulta, edita o elimina la cuenta seleccionada.</p>
      </div>
      <div class="gap-sm">
        <a href="/admin" class="btn btn-secondary">Volver</a>
      </div>
    </header>

    <div id="alert" class="alert hidden"></div>

    <div class="card">
      <div class="card-header">
        <div class="gap-sm" style="gap: 14px;">
          <div class="avatar" id="avatar" style="width:46px;height:46px;font-size:0.95rem;">--</div>
          <div>
            <div class="card-title" id="fullName">Cargando...</div>
            <div class="card-sub" id="emailSub">-</div>
          </div>
        </div>
        <div class="gap-sm">
          <span id="rolesBadges"></span>
        </div>
      </div>

      <div class="section-title">Datos personales</div>
      <form id="editForm">
        <div class="field-row">
          <div class="field">
            <label for="name">Nombres</label>
            <input type="text" id="name" required>
          </div>
          <div class="field">
            <label for="lastName">Apellidos</label>
            <input type="text" id="lastName" required>
          </div>
        </div>
        <div class="field-row">
          <div class="field">
            <label for="phoneNumber">Telefono</label>
            <input type="tel" id="phoneNumber">
          </div>
          <div class="field">
            <label for="birthdate">Fecha de nacimiento</label>
            <input type="date" id="birthdate">
          </div>
        </div>
        <div class="field">
          <label for="email">Correo electronico</label>
          <input type="email" id="email" required>
        </div>

        <div class="section-title" style="margin-top: 22px;">Roles y estado</div>
        <div class="field-row">
          <div class="field">
            <label>Roles asignados</label>
            <div class="checkbox-group" style="padding-top: 8px;">
              <label class="checkbox">
                <input type="checkbox" name="role" value="user">
                <span>Usuario</span>
              </label>
              <label class="checkbox">
                <input type="checkbox" name="role" value="admin">
                <span>Administrador</span>
              </label>
            </div>
          </div>
          <div class="field">
            <label>Estado de la cuenta</label>
            <div class="checkbox-group" style="padding-top: 8px;">
              <label class="checkbox">
                <input type="checkbox" id="active">
                <span>Cuenta activa</span>
              </label>
            </div>
          </div>
        </div>

        <div class="section-title" style="margin-top: 22px;">Seguridad</div>
        <div class="field">
          <label for="password">Nueva contrasena <span class="muted" style="font-weight:400; font-size:0.78rem;">(opcional)</span></label>
          <input type="password" id="password" placeholder="Dejar en blanco para mantener la actual" minlength="6">
        </div>

        <div class="flex-between" style="margin-top: 24px;">
          <button type="button" class="btn btn-danger" id="deleteBtn">Eliminar usuario</button>
          <div class="gap-sm">
            <button type="button" class="btn btn-secondary" id="resetBtn">Descartar</button>
            <button type="submit" class="btn" id="saveBtn">Guardar cambios</button>
          </div>
        </div>
      </form>
    </div>

    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Metadatos</div>
          <div class="card-sub">Informacion del registro.</div>
        </div>
      </div>
      <div class="detail-grid">
        <div class="detail-row"><div class="detail-key">Identificador</div><div class="detail-value" id="metaId" style="font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size:0.85rem;">-</div></div>
        <div class="detail-row"><div class="detail-key">Cuenta creada</div><div class="detail-value" id="metaCreated">-</div></div>
        <div class="detail-row"><div class="detail-key">Ultima actualizacion</div><div class="detail-value" id="metaUpdated">-</div></div>
      </div>
    </div>
  </main>

  <div id="confirmModal" class="modal-backdrop hidden">
    <div class="modal">
      <div class="modal-title">Eliminar usuario</div>
      <p class="modal-sub" id="confirmText">Esta accion no se puede deshacer.</p>
      <div class="modal-actions">
        <button type="button" class="btn btn-secondary" id="cancelDelete">Cancelar</button>
        <button type="button" class="btn btn-danger" id="confirmDelete">Si, eliminar</button>
      </div>
    </div>
  </div>

  <script src="/js/auth.js"></script>
  <script>
    if (Auth.requireRole('admin')) {
      mountNav('admin');
      const userId = '<%= userId %>';
      let original = null;

      function fillSummary(u) {
        const ini = ((u.name || '?').charAt(0) + (u.lastName || '').charAt(0)).toUpperCase();
        document.getElementById('avatar').textContent = ini || '--';
        document.getElementById('fullName').textContent = (u.name || '') + ' ' + (u.lastName || '');
        document.getElementById('emailSub').textContent = u.email || '';
        const roles = (u.roles || []).map(r => r.name || r);
        document.getElementById('rolesBadges').innerHTML = roles.map(r =>
          '<span class="badge ' + (r === 'admin' ? 'badge-admin' : 'badge-user') + '">' + r + '</span>'
        ).join(' ');
        document.getElementById('metaId').textContent = u._id || '-';
        document.getElementById('metaCreated').textContent = fmtDateTime(u.createdAt);
        document.getElementById('metaUpdated').textContent = fmtDateTime(u.updatedAt);
      }

      function fillForm(u) {
        document.getElementById('name').value = u.name || '';
        document.getElementById('lastName').value = u.lastName || '';
        document.getElementById('phoneNumber').value = u.phoneNumber || '';
        document.getElementById('birthdate').value = toInputDate(u.birthdate);
        document.getElementById('email').value = u.email || '';
        document.getElementById('password').value = '';
        document.getElementById('active').checked = u.active !== false;

        const roles = (u.roles || []).map(r => r.name || r);
        document.querySelectorAll('input[name="role"]').forEach(cb => {
          cb.checked = roles.includes(cb.value);
        });
      }

      document.getElementById('resetBtn').addEventListener('click', () => {
        if (original) fillForm(original);
        clearAlert('#alert');
      });

      document.getElementById('editForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        clearAlert('#alert');

        const roles = Array.from(document.querySelectorAll('input[name="role"]:checked'))
          .map(cb => cb.value);
        if (!roles.length) {
          showAlert('#alert', 'El usuario debe tener al menos un rol.');
          return;
        }

        const payload = {
          name: document.getElementById('name').value.trim(),
          lastName: document.getElementById('lastName').value.trim(),
          phoneNumber: document.getElementById('phoneNumber').value.trim(),
          birthdate: document.getElementById('birthdate').value || null,
          email: document.getElementById('email').value.trim(),
          roles,
          active: document.getElementById('active').checked
        };
        const pwd = document.getElementById('password').value;
        if (pwd) {
          if (pwd.length < 6) {
            showAlert('#alert', 'La contrasena debe tener al menos 6 caracteres.');
            return;
          }
          payload.password = pwd;
        }

        const btn = document.getElementById('saveBtn');
        btn.disabled = true;
        btn.textContent = 'Guardando...';
        try {
          const updated = await Auth.api('/api/users/' + userId, { method: 'PUT', body: payload });
          original = updated;
          fillSummary(updated);
          fillForm(updated);
          showAlert('#alert', 'Usuario actualizado correctamente.', 'success');
        } catch (err) {
          showAlert('#alert', err.message || 'No se pudo actualizar el usuario.');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Guardar cambios';
        }
      });

      const modal = document.getElementById('confirmModal');
      document.getElementById('deleteBtn').addEventListener('click', () => {
        document.getElementById('confirmText').textContent =
          'Vas a eliminar a "' + (original?.name || '') + ' ' + (original?.lastName || '') + '". Esta accion no se puede deshacer.';
        modal.classList.remove('hidden');
      });
      document.getElementById('cancelDelete').addEventListener('click', () => {
        modal.classList.add('hidden');
      });
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.classList.add('hidden');
      });
      document.getElementById('confirmDelete').addEventListener('click', async () => {
        try {
          await Auth.api('/api/users/' + userId, { method: 'DELETE' });
          window.location.replace('/admin?deleted=1');
        } catch (err) {
          modal.classList.add('hidden');
          showAlert('#alert', err.message || 'No se pudo eliminar el usuario.');
        }
      });

      (async function load() {
        try {
          const u = await Auth.api('/api/users/' + userId);
          original = u;
          fillSummary(u);
          fillForm(u);
        } catch (err) {
          showAlert('#alert', err.message || 'No se pudo cargar el usuario.');
        }
      })();
    }
  </script>
</body>
</html>
