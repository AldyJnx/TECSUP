{
  "info": {
    "name": "Registro Cloud Innovation Day",
    "description": "Coleccion de pruebas para la API serverless de estudiantes (AWS Lambda + API Gateway + DynamoDB). Antes de usar, define la variable {{baseUrl}} con la URL de invoke de tu API Gateway.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://TU_API_ID.execute-api.TU_REGION.amazonaws.com/prod",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Registrar estudiante (POST)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"E001\",\n  \"nombres\": \"Luis Angel\",\n  \"apellidos\": \"Campos Valenzuela\",\n  \"correo\": \"luis.campos@tecsup.edu.pe\",\n  \"carrera\": \"Diseno y Desarrollo de Software\",\n  \"ciclo\": \"5\",\n  \"fechaRegistro\": \"2026-06-30\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/estudiantes",
          "host": ["{{baseUrl}}"],
          "path": ["estudiantes"]
        }
      }
    },
    {
      "name": "2. Listar estudiantes (GET)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/estudiantes",
          "host": ["{{baseUrl}}"],
          "path": ["estudiantes"]
        }
      }
    },
    {
      "name": "3. Consultar estudiante por id (GET)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/estudiantes/E001",
          "host": ["{{baseUrl}}"],
          "path": ["estudiantes", "E001"]
        }
      }
    },
    {
      "name": "4. Eliminar estudiante por id (DELETE)",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/estudiantes/E001",
          "host": ["{{baseUrl}}"],
          "path": ["estudiantes", "E001"]
        }
      }
    }
  ]
}
